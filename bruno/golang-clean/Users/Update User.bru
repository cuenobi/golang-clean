meta {
  name: Update User
  type: http
  seq: 4
}

put {
  url: {{base_url}}/api/v1/users/{{userId}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  X-API-Key: {{apiKey}}
  X-Permissions: {{userPermissionsWrite}}
}

body:json {
  {
    "name": "Alice Updated",
    "email": "alice.updated@example.com"
  }
}
