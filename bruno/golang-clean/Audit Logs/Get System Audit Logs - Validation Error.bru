meta {
  name: Get System Audit Logs - Validation Error
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/v1/audit-logs/system?date_from=invalid-date&date_to=2026-04-30T23:59:59Z
  body: none
  auth: none
}

headers {
