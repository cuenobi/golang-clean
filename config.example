# App
APP_NAME=golang-clean
APP_ENV=dev
LOG_LEVEL=info

# HTTP
HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=15
READINESS_DB_TIMEOUT_MS=1500

# Security
AUTH_ENABLED=false
API_KEY=change-me
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SEC=60

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=oms_user
POSTGRES_PASS=oms_password
POSTGRES_DB=oms_db
POSTGRES_SSL_MODE=disable

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_PUBLISH_TIMEOUT_MS=3000

# Outbox / Dispatcher
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5
OUTBOX_RETRY_BACKOFF_MS=500
OUTBOX_PROCESSING_TIMEOUT_MS=15000

# Circuit Breaker
CIRCUIT_BREAKER_FAILURES=5
CIRCUIT_BREAKER_OPEN_MS=30000
