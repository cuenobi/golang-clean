meta {
  name: Create User
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/users
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  X-API-Key: {{apiKey}}
  X-Permissions: {{userPermissionsWrite}}
}

body:json {
  {
    "name": "Alice",
    "email": "alice@example.com"
  }
}
